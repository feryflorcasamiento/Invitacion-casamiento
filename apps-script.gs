const SHEET_NAME="Hoja 1";
const EMAIL_DESTINO="feryflorcasamiento@gmail.com";
function doGet(e){const cb=e.parameter.callback||"callback";const r=e.parameter.action==="getGuest"?getGuest_(e.parameter.id):{ok:false};return ContentService.createTextOutput(`${cb}(${JSON.stringify(r)})`).setMimeType(ContentService.MimeType.JAVASCRIPT)}
function doPost(e){const r=e.parameter.action==="rsvp"?saveRsvp_(e.parameter):{ok:false};return ContentService.createTextOutput(JSON.stringify(r)).setMimeType(ContentService.MimeType.JSON)}
function sh_(){const s=SpreadsheetApp.getActiveSpreadsheet().getSheetByName(SHEET_NAME);if(!s)throw new Error(`No existe ${SHEET_NAME}`);return s}
function nid_(v){return String(v||"").trim().padStart(3,"0")}
function getGuest_(id){const v=sh_().getDataRange().getDisplayValues(),t=nid_(id);for(let i=1;i<v.length;i++)if(nid_(v[i][0])===t)return{ok:true,id:t,guests:v[i].slice(1,5)};return{ok:false}}
function saveRsvp_(p){const s=sh_(),v=s.getDataRange().getDisplayValues(),t=nid_(p.id),a=JSON.parse(p.attendance||"[]");for(let i=1;i<v.length;i++){if(nid_(v[i][0])!==t)continue;const g=v[i].slice(1,5),n=[0,1,2,3].map(x=>g[x]?(a[x]||"No"):""),total=n.filter(x=>x==="Sí").length,status=total?"Confirmado":"No asisten",row=i+1;s.getRange(row,6,1,9).setValues([[n[0],n[1],n[2],n[3],total,p.song||"",p.food||"",new Date(),status]]);const yes=g.filter((x,j)=>x&&n[j]==="Sí"),no=g.filter((x,j)=>x&&n[j]==="No");MailApp.sendEmail({to:EMAIL_DESTINO,subject:`Confirmación boda · Invitación ${t}`,htmlBody:`<h2>Nueva confirmación</h2><p><b>Asisten:</b> ${yes.join(", ")||"Nadie"}</p><p><b>No asisten:</b> ${no.join(", ")||"-"}</p><p><b>Canción:</b> ${p.song||"-"}</p><p><b>Restricciones:</b> ${p.food||"-"}</p>`});return{ok:true}}return{ok:false}}